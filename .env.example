# Bezpečnostní klíč — změnit na náhodný řetězec v produkci
SECRET_KEY=zmenit-na-nahodny-retezec-v-produkci

# Bcrypt hash hesla pro přihlášení
# Vygenerovat pomocí: python setup.py
PASSWORD_HASH=

# Databáze
DATABASE_URL=sqlite:///./faktury.db

# Adresář pro uploady příloh
UPLOAD_DIR=uploads

# IBAN pro QR kód platby (ověřit s bankou!)
# Pokud je číslo účtu ve formátu PREFIX-CISLO/BANKA, IBAN se vypočítá automaticky.
# Pro 294891-30140/3030 (Air Bank) = CZ3630302948910000030140
# Pokud je účet zadán bez pomlčky (XXXXXXXXXX/XXXX), nastavte IBAN ručně:
SUPPLIER_IBAN=CZ3630302948910000030140

# Volitelné přepsání výchozích hodnot dodavatele
# SUPPLIER_NAME=Vlastník Aplikace
# SUPPLIER_STREET=Ulice XX
# SUPPLIER_CITY=Město
# SUPPLIER_ZIP=XXX XX
# SUPPLIER_ICO=XXXXXXXX
# SUPPLIER_DIC=CZXXXXXXXXXX
# SUPPLIER_ACCOUNT=XXXXXXXXXX/XXXX
# SUPPLIER_EMAIL=owner@example.com
# SUPPLIER_PHONE=XXXXXXXXXX
